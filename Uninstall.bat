@echo off
chcp 65001 >nul
title Деинсталлятор Калькулятора

echo ===================================================
echo             УДАЛЕНИЕ КАЛЬКУЛЯТОРА
echo ===================================================
echo.
echo Внимание! Вы собираетесь удалить Калькулятор.
echo Эта операция удалит:
echo   - Ярлык с Рабочего стола (если есть)
echo   - EXE файл из папки dist\
echo   - Временные файлы кэша
echo.

set /p confirm="Вы уверены, что хотите продолжить? (Y/N): "
if /I "%confirm%" NEQ "Y" (
    echo.
    echo Удаление отменено.
    pause
    exit
)

echo.
echo [1/3] Удаление ярлыка с Рабочего стола...
if exist "%USERPROFILE%\Desktop\Калькулятор.lnk" (
    del "%USERPROFILE%\Desktop\Калькулятор.lnk"
    echo     Ярлык успешно удален.
) else (
    echo     Ярлык на Рабочем столе не найден — пропускаем.
)

echo.
echo [2/3] Удаление EXE файла...
if exist "%~dp0dist\Калькулятор.exe" (
    del "%~dp0dist\Калькулятор.exe"
    echo     EXE файл успешно удален.
) else (
    echo     EXE файл не найден — пропускаем.
)

echo.
echo [3/3] Очистка кэша и временных файлов...
if exist "%~dp0__pycache__" (
    rmdir /S /Q "%~dp0__pycache__"
    echo     Кэш Python очищен.
) else (
    echo     Кэш не найден — пропускаем.
)
if exist "%~dp0build" (
    rmdir /S /Q "%~dp0build"
    echo     Папка build удалена.
)

echo.
echo ===================================================
echo Готово! Программа удалена.
echo Если вы хотите убрать всё полностью — просто
echo удалите папку "%~dp0"
echo ===================================================
echo.
pause
