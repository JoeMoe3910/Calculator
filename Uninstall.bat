@echo off
chcp 65001 >nul
title Деинсталлятор Калькулятора

echo ===================================================
echo             УДАЛЕНИЕ КАЛЬКУЛЯТОРА
echo ===================================================
echo.
echo Внимание! Вы собираетесь удалить Калькулятор.
echo Эта операция удалит ярлык с Рабочего стола.
echo.

set /p confirm="Вы уверены, что хотите продолжить? (Y/N): "
if /I "%confirm%" NEQ "Y" (
    echo.
    echo Удаление отменено.
    pause
    exit
)

echo.
echo [1/2] Удаление ярлыка с Рабочего стола...
if exist "%USERPROFILE%\Desktop\Калькулятор.lnk" (
    del "%USERPROFILE%\Desktop\Калькулятор.lnk"
    echo Ярлык успешно удален.
) else (
    echo Ярлык на Рабочем столе не найден.
)

echo.
echo [2/2] Очистка кэша...
if exist "%~dp0__pycache__" (
    rmdir /S /Q "%~dp0__pycache__"
)

echo.
echo ===================================================
echo Готово! Если вы хотите полностью удалить программу,
echo просто удалите эту папку ("%~dp0").
echo ===================================================
echo.
pause
